# ============================================================================
# Whitelistarr configuration. Copy to .env and fill in.
#
# Two ways to configure:
#   1. UI-first  — set the BOOTSTRAP block, boot, then configure in the web UI
#      (Plex sign-in, *arr keys, tag map, schedules). Changes apply live.
#   2. Declarative — also set the CORE block here for a headless deploy.
#
# Everything below the CORE block is OPTIONAL (sane defaults). The full list of
# advanced overrides lives in the README "Advanced overrides" section.
# ============================================================================

# --- BOOTSTRAP (read from env only; changing these needs a restart) ---
# Required when the UI is on. Encrypts secrets at rest. Generate once with:
#   openssl rand -base64 32 | tr '+/' '-_'
PAL_SECRET_KEY=
# FEATURE_UI=true serves a config UI at http://host:8000/ . It has NO built-in
# auth, so keep it behind your reverse proxy / trusted network.
FEATURE_UI=true
CONFIG_PATH=/data/config.json
STATE_DB_PATH=/data/state.db
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000

# --- CORE (or configure these in the UI after first boot) ---
# Plex: paste a token, or use "Sign in with Plex" in the UI (fills URL + token).
PLEX_URL=http://plex:32400
PLEX_TOKEN=
RADARR_URL=http://radarr:7878
RADARR_API_KEY=
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=
# Tag -> label mapping (the core of the service): "<arr-tag>:<plex-label>,..."
# Tags not listed are ignored. Restrict a shared user to the Plex label(s) here.
TAG_LABEL_MAP=kids:kids-allowed,family:shared

# --- SCHEDULES (5-field cron; defaults shown) ---
# Sweep is the only job that reconciles tag add/remove on existing items
# (including access revokes), so keep it frequent.
SWEEP_CRON=0 * * * *        # hourly
WATCH_SCAN_CRON=0 3 * * *   # daily 3am  (only used when FEATURE_NOTIFY=true)

# --- Notifications (optional; Apprise) ---
# Comma-separated Apprise URLs: https://github.com/caronc/apprise/wiki
APPRISE_URLS=
# Which events to notify on: watched, stale (need FEATURE_NOTIFY + Tautulli);
# labeled (only needs APPRISE_URLS).
NOTIFY_ON=watched,stale
FEATURE_NOTIFY=false
# Seerr/Tautulli are only needed for watched/stale notifications.
# (Legacy OVERSEERR_URL / OVERSEERR_API_KEY are still accepted.)
SEERR_URL=http://seerr:5055
SEERR_API_KEY=
TAUTULLI_URL=http://tautulli:8181
TAUTULLI_API_KEY=

# --- Container ---
TZ=UTC
# Container drops from root to this user/group (fixes /data ownership first).
PUID=1000
PGID=1000

# ----------------------------------------------------------------------------
# Advanced overrides (rarely needed; documented in the README). All have sane
# defaults — uncomment only to change them:
#   PLEX_SECTIONS=Movies,TV Shows   # empty = all movie/show sections
#   PLEX_DEVICE_NAME=Whitelistarr   # shown in Plex > Settings > Devices
#   PLEX_CLIENT_ID=                 # auto-generated + persisted on first run
#   LABEL_REMOVAL=reconcile         # reconcile (add+remove) | add-only
#   FEATURE_WEBHOOK=true
#   WEBHOOK_PATH=/webhook/seerr
#   PLEX_WEBHOOK_PATH=/webhook/plex
#   WEBHOOK_SECRET=                 # if set, callers use ...{path}?token=THIS
#   WATCHED_PERCENT=85
#   STALE_AFTER_DAYS=180
#   UNWATCHED_AFTER_DAYS=90
#   DRY_RUN=false                   # log intended changes, touch nothing
#   LOG_LEVEL=info
# REVERSE=true is a one-shot teardown (removes managed labels from every item,
# then exits). Run it as a one-off, not as routine config.
# ----------------------------------------------------------------------------
