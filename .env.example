# ============================================================================
# Whitelistarr configuration. Copy to .env and fill in.
# All configuration is via environment variables (declarative / 12-factor).
# ============================================================================

# --- Plex (server owner; Plex Pass required for label-based share filtering) ---
PLEX_URL=http://plex:32400
PLEX_TOKEN=your-plex-token
# Comma-separated section names to process. Empty = all movie/show sections.
PLEX_SECTIONS=Movies,TV Shows
# How this app shows up in Plex > Settings > Devices. A stable client id avoids
# a new device entry on each restart.
PLEX_DEVICE_NAME=Whitelistarr
PLEX_CLIENT_ID=whitelistarr

# --- Radarr (movies) ---
RADARR_URL=http://radarr:7878
RADARR_API_KEY=your-radarr-key

# --- Sonarr (TV) ---
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=your-sonarr-key

# --- Seerr / Overseerr (request -> requester mapping; webhook source) ---
# (Legacy OVERSEERR_URL / OVERSEERR_API_KEY are still accepted.)
SEERR_URL=http://seerr:5055
SEERR_API_KEY=your-seerr-key

# --- Tautulli (watch history; only required if FEATURE_NOTIFY=true) ---
TAUTULLI_URL=http://tautulli:8181
TAUTULLI_API_KEY=your-tautulli-key

# ----------------------------------------------------------------------------
# Tag -> label mapping (the core of the service).
# "<arr-tag>:<plex-label>,..."  Tags not listed here are ignored. Restrict a
# shared user's library to the Plex label(s) you map to here.
# ----------------------------------------------------------------------------
TAG_LABEL_MAP=kids:kids-allowed,family:shared

# reconcile = add AND remove mapped labels to stay in true sync (recommended).
# add-only  = only ever add labels, never remove.
LABEL_REMOVAL=reconcile

# --- Feature toggles ---
FEATURE_WEBHOOK=true
FEATURE_SWEEP=true
SWEEP_INTERVAL_MINUTES=60
FEATURE_NOTIFY=false
WATCH_SCAN_INTERVAL_MINUTES=360

# --- Notifications (Apprise) ---
# Comma-separated Apprise URLs: https://github.com/caronc/apprise/wiki
APPRISE_URLS=
# Which events to notify on. Options:
#   watched, stale  -> need Tautulli (FEATURE_NOTIFY=true)
#   labeled         -> ping when new items get whitelisted (only needs APPRISE_URLS)
NOTIFY_ON=watched,stale
# Send one real test notification at startup to verify channels (ignores DRY_RUN).
NOTIFY_TEST_ON_START=false
WATCHED_PERCENT=85
STALE_AFTER_DAYS=180
UNWATCHED_AFTER_DAYS=90

# --- Web UI (served on the same port) ---
# FEATURE_UI=true serves a config UI at http://host:8000/ . It has NO built-in auth,
# so keep it behind your reverse proxy / trusted network.
FEATURE_UI=true
# Required when the UI is on. Encrypts secrets at rest. Generate once with:
#   openssl rand -base64 32 | tr '+/' '-_'
PAL_SECRET_KEY=
# Where the UI persists config (on the /data volume).
CONFIG_PATH=/data/config.json

# --- Server / ops ---
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_PATH=/webhook/seerr
# Plex webhook route (Plex Pass). Set a Plex webhook to this for immediate
# labeling without configuring Seerr (also catches manually-added content).
PLEX_WEBHOOK_PATH=/webhook/plex
# Optional shared secret. If set, callers must use ...{WEBHOOK_PATH}?token=THIS
WEBHOOK_SECRET=
# DRY_RUN=true logs intended changes without touching Plex or sending notifications.
DRY_RUN=false
# REVERSE=true is a one-shot teardown: removes the managed label(s) from EVERY
# Plex item, then exits (no webhook/scheduler). Respects DRY_RUN.
REVERSE=false
LOG_LEVEL=info
STATE_DB_PATH=/data/state.db
TZ=UTC
# Container drops from root to this user/group (fixes /data ownership first).
# Set to your host user (id -u / id -g) if the bind-mounted ./data isn't writable.
PUID=1000
PGID=1000
